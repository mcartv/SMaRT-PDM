# Backend environment variables for local dev and production
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
FCM_SERVER_KEY=
INTERNAL_NOTIFICATION_SECRET=replace-with-a-shared-internal-secret
GMAIL_APP_PASSWORD=your-gmail-app-password
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_PHONE=+15555550123
GOOGLE_CLOUD_PROJECT_ID=your-google-cloud-project-id
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
RECAPTCHA_ANDROID_SITE_KEY=your-android-site-key
RECAPTCHA_MIN_SCORE=0.5
PORT=3000
